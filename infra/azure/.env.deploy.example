# Values to gather before deploying telecode to Azure. This is a CHECKLIST — do NOT commit a filled copy.
# Most of these are passed to `az deployment group create` (Bicep params) or set as GitHub Actions
# secrets/vars. See docs/deploy-azure.md for the exact commands.

# --- Azure targets ----------------------------------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=telecode-prod
AZURE_LOCATION=eastus

# --- Public config (Bicep params; not secret) -------------------------------
APP_HOSTNAME=app.telecode.io
RELAY_HOSTNAME=relay.telecode.io
VAPID_SUBJECT=mailto:admin@telecode.io
VAPID_PUBLIC_KEY=            # from: npx web-push generate-vapid-keys
GITHUB_CLIENT_ID=           # GitHub OAuth App (callback https://app.telecode.io/auth/github/callback)
RATELIMIT_ALLOWLIST=        # set AFTER the env exists, to its outbound/static IP (see runbook)

# --- Secrets (Bicep secure params + GH Actions secret for migrations) --------
DATABASE_URL=               # Supabase SESSION POOLER URI (IPv4), end it with ?sslmode=no-verify
                            #   ...pooler.supabase.com:5432/postgres?sslmode=no-verify
                            #   (no-verify: encrypted but skips chain validation — Supabase's pooler cert
                            #    isn't in Node's default CA bundle; 'require' now means strict verify-full)
CHANNEL_TOKEN_SECRET=       # openssl rand -base64 32
RELAY_SERVICE_SECRET=       # openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=       # openssl rand -base64 32  (must be exactly 32 bytes base64)
VAPID_PRIVATE_KEY=          # from: npx web-push generate-vapid-keys
GITHUB_CLIENT_SECRET=       # GitHub OAuth App generated secret

# --- GitHub Actions OIDC (for the deploy workflow) --------------------------
AZURE_CLIENT_ID=            # the Entra app (federated credential) client id
AZURE_TENANT_ID=
# GH repo VARIABLES: AZURE_RESOURCE_GROUP, ACR_NAME, RELAY_APP_NAME (telecode-relay), WEB_APP_NAME (telecode-web)
# GH repo SECRETS:   AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_SUBSCRIPTION_ID, DATABASE_URL
