# Telecode self-host configuration. Copy to `infra/.env` and fill in. Compose reads this file
# automatically (`docker compose -f infra/docker-compose.yml up`). NEVER commit infra/.env.
#
# Generate a strong secret with:  openssl rand -base64 32

# --- Required ---------------------------------------------------------------

# Postgres password for the bundled database (used to build DATABASE_URL inside the compose network).
POSTGRES_PASSWORD=

# Signs the short-lived browser channel tokens. Long random string.
CHANNEL_TOKEN_SECRET=

# Shared secret the web tier presents on server-to-server relay calls (/auth/session, /device/approve).
RELAY_SERVICE_SECRET=

# --- Optional features (each enables only when set) -------------------------

# Encrypts the user's GitHub access token at rest + enables repo listing for the launch picker.
# Must be a base64-encoded 32-byte key:  openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Web push (VAPID). Generate a keypair with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Tunables ---------------------------------------------------------------

# Host port the relay is published on (container always listens on 8080).
RELAY_PORT=8080
LOG_LEVEL=info

# --- Rate limiting / abuse prevention ---------------------------------------
# The relay rate-limits HTTP requests by client IP (on by default — safe to leave running publicly).
# The bundle wires Redis automatically (REDIS_URL=redis://redis:6379 in compose) to share the budget.

# Trust X-Forwarded-For so the per-IP limit keys on the real client, not your proxy. Defaults to true in
# the bundle (it assumes you terminate TLS in front of the relay). Set false ONLY if clients connect to
# the relay directly with no proxy — otherwise every client shares one budget.
TRUST_PROXY=true

# Comma-separated IPs that are never rate-limited — set this to your web tier's egress IP(s); its traffic
# aggregates every user, so without exempting it the limiter could throttle your whole user base.
RATELIMIT_ALLOWLIST=

# Optional overrides (defaults: 300 requests per '1 minute', per IP). Window is a humanized duration.
RATELIMIT_MAX=
RATELIMIT_WINDOW=

# Set to true to turn HTTP rate limiting OFF entirely (not recommended for a public relay).
RATELIMIT_DISABLED=

# Max request body size in bytes (default 65536). The relay's bodies are tiny JSON; oversized → 413.
BODY_LIMIT=

# Max concurrent WebSocket connections per client IP (default 32). Bounds how many sockets one client may
# hold open. Behind NAT a daemon + several browser tabs share an IP, so keep this comfortably above 1.
MAX_WS_CONNECTIONS_PER_IP=

# --- Telemetry (off by default — telecode collects nothing) -----------------
# Opt in to aggregate, identifier-free operational metrics that go ONLY to this relay's own logs (no
# network/third-party sink exists in the codebase). See docs/telemetry.md. Set to on/true to enable.
TELECODE_TELEMETRY=
