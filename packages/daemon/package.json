{
  "name": "@telecode/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The telecode daemon — runs Claude Code agents on your machine, dialing out to the relay.",
  "license": "AGPL-3.0-only",
  "author": "Pouyan Jahangiri",
  "homepage": "https://telecode.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PouyanJay/telecode.git",
    "directory": "packages/daemon"
  },
  "bugs": {
    "url": "https://github.com/PouyanJay/telecode/issues"
  },
  "keywords": [
    "telecode",
    "claude",
    "claude-code",
    "agent",
    "coding-agent",
    "self-hosted",
    "daemon",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "telecode": "bin/telecode.mjs"
  },
  "files": [
    "bin",
    "src",
    "!src/**/*.test.ts",
    "!src/spike-agent-sdk.ts"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "spike:agent-sdk": "node --import tsx --env-file=../../.env src/spike-agent-sdk.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.186",
    "@telecode/protocol": "workspace:*",
    "pino": "^9.6.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
