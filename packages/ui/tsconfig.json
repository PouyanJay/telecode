{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    // The design system is browser-targeted (Svelte components + DOM `use:` actions), so it needs the
    // DOM lib on top of the base ES libs.
    "lib": ["ES2023", "DOM", "DOM.Iterable"]
  },
  "include": ["src"]
}
