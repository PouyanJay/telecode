{
  "name": "@telecode/relay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "db:reset": "tsx src/db/reset-dev.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.2",
    "@telecode/protocol": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "pino": "^9.6.0",
    "tsx": "^4.19.2",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@telecode/daemon": "workspace:*",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
